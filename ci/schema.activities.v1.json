{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.activities.v1.json",
  "title": "Luming Activity Library v1",
  "type": "object",
  "required": ["version", "activities"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "activities": {
      "type": "array",
      "minItems": 30,
      "items": { "$ref": "#/definitions/Activity" }
    }
  },
  "definitions": {
    "Activity": {
      "type": "object",
      "required": ["id", "name", "category", "duration_min", "steps", "context_tags"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        },
        "category": {
          "type": "string",
          "enum": ["stretch", "meditation", "breathing", "walk", "focus", "movement", "rest"]
        },
        "duration_min": {
          "type": "integer",
          "minimum": 5,
          "maximum": 20
        },
        "steps": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/definitions/Step" }
        },
        "context_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["morning", "afternoon", "evening", "night", "hot", "cold", "rainy", "clear", "indoor", "outdoor"]
          },
          "uniqueItems": true
        }
      }
    },
    "Step": {
      "type": "object",
      "required": ["order", "text"],
      "additionalProperties": false,
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    }
  }
}
