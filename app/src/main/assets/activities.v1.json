{
  "version": "1",
  "activities": [
    {
      "id": "stretch_neck_roll_01",
      "name": "목 돌리기",
      "category": "stretch",
      "duration_min": 5,
      "steps": [
        {
          "order": 1,
          "text": "의자나 바닥에 허리를 곧게 펴고 어깨에 힘을 빼고 앉으세요."
        },
        {
          "order": 2,
          "text": "오른쪽 귀를 오른쪽 어깨로 기울여 5번 천천히 호흡하세요. 왼쪽 목이 늘어나는 걸 느껴보세요."
        },
        {
          "order": 3,
          "text": "턱을 가슴으로 내려 3번 호흡하고, 왼쪽 어깨로 굴려 5번 호흡하세요."
        },
        {
          "order": 4,
          "text": "중앙으로 돌아와 어깨에서 어깨로 반원을 그리며 양방향 3번씩 부드럽게 돌리세요."
        }
      ],
      "context_tags": [
        "morning",
        "afternoon",
        "indoor"
      ]
    },
    {
      "id": "stretch_shoulder_open_02",
      "name": "어깨 열기 스트레칭",
      "category": "stretch",
      "duration_min": 8,
      "steps": [
        {
          "order": 1,
          "text": "바르게 서거나 앉아 등 뒤로 손가락을 깍지 끼고 팔을 펴세요."
        },
        {
          "order": 2,
          "text": "양쪽 날개뼈를 모으고 손을 등에서 멀리 들어올려 5번 호흡하세요."
        },
        {
          "order": 3,
          "text": "오른팔을 가슴 앞으로 가로질러 왼손으로 살짝 당겨 5번 호흡하세요."
        },
        {
          "order": 4,
          "text": "반대쪽도 5번 호흡하세요. 전체를 2번 더 반복하세요."
        }
      ],
      "context_tags": [
        "afternoon",
        "indoor"
      ]
    },
    {
      "id": "stretch_spine_twist_03",
      "name": "앉아서 척추 비틀기",
      "category": "stretch",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "다리를 펴고 바닥에 앉아 오른 무릎을 세워 발을 왼 허벅지 바깥에 두세요."
        },
        {
          "order": 2,
          "text": "들이쉬며 바르게 앉고, 내쉬며 상체를 오른쪽으로 돌려 왼 팔꿈치를 오른 무릎 바깥에 거세요."
        },
        {
          "order": 3,
          "text": "오른손을 등 뒤 바닥에 짚고 6번 호흡하세요. 들이쉴 때마다 척추를 길게 늘이세요."
        },
        {
          "order": 4,
          "text": "풀고 중앙으로 돌아와 반대쪽도 하세요. 양쪽 2번씩 반복하세요."
        }
      ],
      "context_tags": [
        "evening",
        "indoor"
      ]
    },
    {
      "id": "stretch_hip_flexor_04",
      "name": "고관절 풀기",
      "category": "stretch",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "오른 무릎을 꿇고 왼발을 앞으로 내딛어 낮은 런지 자세를 만든 뒤 양손을 왼 무릎에 얹으세요."
        },
        {
          "order": 2,
          "text": "상체를 세운 채 골반을 앞으로 살짝 밀어 오른쪽 고관절 앞이 늘어나는 걸 느끼세요."
        },
        {
          "order": 3,
          "text": "6번 호흡하세요. 내쉴 때마다 무리하지 말고 골반을 조금씩 더 내리세요."
        },
        {
          "order": 4,
          "text": "풀고 반대쪽도 반복하세요. 양쪽 2번씩 하세요."
        }
      ],
      "context_tags": [
        "afternoon",
        "indoor"
      ]
    },
    {
      "id": "stretch_forward_fold_05",
      "name": "선 채로 앞으로 굽히기",
      "category": "stretch",
      "duration_min": 5,
      "steps": [
        {
          "order": 1,
          "text": "발을 골반 너비로 벌리고 서서 들이쉬며 척추를 길게 늘이세요."
        },
        {
          "order": 2,
          "text": "내쉬며 골반을 접어 앞으로 숙이세요. 머리와 팔은 힘을 빼고, 필요하면 무릎을 살짝 굽히세요."
        },
        {
          "order": 3,
          "text": "8번 호흡하세요. 내쉴 때마다 다리 뒤와 허리의 긴장을 풀어주세요."
        },
        {
          "order": 4,
          "text": "올라올 땐 무릎을 굽히고 손을 허벅지에 짚어 척추를 하나씩 세우며 천천히 일어나세요."
        }
      ],
      "context_tags": [
        "morning",
        "indoor",
        "outdoor",
        "clear"
      ]
    },
    {
      "id": "stretch_cat_cow_06",
      "name": "고양이-소 자세",
      "category": "stretch",
      "duration_min": 8,
      "steps": [
        {
          "order": 1,
          "text": "손목은 어깨 아래, 무릎은 골반 아래에 두고 네발 자세로 시작하세요. 척추는 중립으로."
        },
        {
          "order": 2,
          "text": "들이쉬며 배를 바닥으로 내리고 꼬리뼈와 가슴을 들어올리세요(소 자세). 시선은 살짝 앞으로."
        },
        {
          "order": 3,
          "text": "내쉬며 척추를 천장으로 둥글게 말고 턱과 꼬리뼈를 당기세요(고양이 자세). 손으로 바닥을 밀어내세요."
        },
        {
          "order": 4,
          "text": "들이쉬며 소, 내쉬며 고양이로 10번 호흡 동안 흐르듯 움직이세요. 호흡이 동작을 이끌게 하세요."
        }
      ],
      "context_tags": [
        "morning",
        "evening",
        "indoor"
      ]
    },
    {
      "id": "stretch_chest_opener_07",
      "name": "가슴 열기 스트레칭",
      "category": "stretch",
      "duration_min": 5,
      "steps": [
        {
          "order": 1,
          "text": "문틀이나 벽 옆에 서서 오른 팔뚝을 틀에 대고 팔꿈치를 어깨 높이에 두세요."
        },
        {
          "order": 2,
          "text": "몸을 왼쪽으로 천천히 돌려 오른쪽 가슴과 어깨가 늘어나는 걸 느끼세요."
        },
        {
          "order": 3,
          "text": "5번 호흡한 뒤 팔을 바꿔 반대쪽도 하세요."
        },
        {
          "order": 4,
          "text": "더 깊게 하려면 팔꿈치를 어깨보다 살짝 높여 다시 돌리세요. 양쪽 2번씩 하세요."
        }
      ],
      "context_tags": [
        "afternoon",
        "indoor"
      ]
    },
    {
      "id": "stretch_hamstring_release_08",
      "name": "햄스트링 풀기",
      "category": "stretch",
      "duration_min": 12,
      "steps": [
        {
          "order": 1,
          "text": "등을 대고 누워 두 무릎을 세우고 발을 바닥에 평평히 두세요."
        },
        {
          "order": 2,
          "text": "오른 다리를 들어 허벅지 뒤를 잡고 편한 만큼 무릎을 펴세요. 발끝은 몸쪽으로 당기세요."
        },
        {
          "order": 3,
          "text": "8번 호흡하며 햄스트링을 부드럽게 풀어주세요. 억지로 당기지 말고 호흡으로 늘이세요."
        },
        {
          "order": 4,
          "text": "내리고 반대쪽도 하세요. 다리당 2번씩. 마지막엔 두 무릎을 가슴에 안고 5번 호흡하세요."
        }
      ],
      "context_tags": [
        "evening",
        "indoor"
      ]
    },
    {
      "id": "stretch_sun_salutation_09",
      "name": "가벼운 태양 경배 자세",
      "category": "stretch",
      "duration_min": 15,
      "steps": [
        {
          "order": 1,
          "text": "매트 앞에 바르게 서서 손바닥을 가슴 앞에 모으세요. 깊게 3번 호흡하며 자리를 잡으세요."
        },
        {
          "order": 2,
          "text": "들이쉬며 팔을 머리 위로, 내쉬며 골반을 접어 앞으로 숙이세요. 들이쉬며 척추를 반쯤 펴세요."
        },
        {
          "order": 3,
          "text": "내쉬며 플랭크로 물러나거나 바닥으로 내려가세요. 들이쉬며 가볍게 상체를 들어 올리세요(코브라)."
        },
        {
          "order": 4,
          "text": "내쉬며 다운독 자세로 5번 호흡하세요. 발을 손 쪽으로 옮겨 숙였다가 들이쉬며 일어나세요. 4번 반복하세요."
        }
      ],
      "context_tags": [
        "morning",
        "indoor",
        "outdoor",
        "clear"
      ]
    },
    {
      "id": "stretch_wrist_desk_10",
      "name": "손목과 책상 피로 풀기",
      "category": "stretch",
      "duration_min": 5,
      "steps": [
        {
          "order": 1,
          "text": "오른팔을 앞으로 뻗고 손바닥을 위로, 왼손으로 손가락을 바닥쪽으로 살짝 당기세요."
        },
        {
          "order": 2,
          "text": "5번 호흡한 뒤 손바닥을 아래로 뒤집어 손가락을 위로 당기세요. 5번 호흡하세요."
        },
        {
          "order": 3,
          "text": "왼팔로 바꿔 양방향 모두 반복하세요."
        },
        {
          "order": 4,
          "text": "두 손목을 가볍게 털고, 양방향으로 천천히 주먹을 5번씩 돌리며 마무리하세요."
        }
      ],
      "context_tags": [
        "afternoon",
        "indoor"
      ]
    },
    {
      "id": "meditation_breath_count_01",
      "name": "호흡 세기 명상",
      "category": "meditation",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "척추를 세우고 편하게 앉으세요. 눈을 감거나 시선을 아래로 부드럽게 두고 손은 허벅지에 얹으세요."
        },
        {
          "order": 2,
          "text": "자연스럽게 호흡하세요. 내쉴 때마다 속으로 하나, 둘, 셋… 열까지 센 뒤 다시 하나로 돌아오세요."
        },
        {
          "order": 3,
          "text": "생각이 흩어져 숫자를 놓치면 자책 없이 다시 하나로 돌아오세요. 알아차림이 곧 수련이에요."
        },
        {
          "order": 4,
          "text": "끝까지 이어가세요. 마지막엔 깊게 들이쉬고 길게 내쉰 뒤 천천히 눈을 뜨세요."
        }
      ],
      "context_tags": [
        "morning",
        "indoor"
      ]
    },
    {
      "id": "meditation_body_scan_02",
      "name": "바디 스캔 명상",
      "category": "meditation",
      "duration_min": 15,
      "steps": [
        {
          "order": 1,
          "text": "등을 대고 눕거나 편하게 앉으세요. 눈을 감고 천천히 3번 호흡하며 자리를 잡으세요."
        },
        {
          "order": 2,
          "text": "정수리에 주의를 가져가세요. 따뜻함, 저릿함, 혹은 아무 느낌이든 그대로 관찰하세요."
        },
        {
          "order": 3,
          "text": "주의를 천천히 아래로 옮기세요. 얼굴, 턱, 목, 어깨, 팔, 손, 가슴, 배, 골반, 다리, 발 순으로."
        },
        {
          "order": 4,
          "text": "각 부위에서 2~3번 호흡하며 관찰하세요. 긴장이 있으면 숨을 불어넣어 내쉴 때 풀어주세요."
        },
        {
          "order": 5,
          "text": "마지막엔 온몸을 한 번에 느끼며 5번 호흡하세요. 깊게 숨 쉬고 손발을 움직인 뒤 돌아오세요."
        }
      ],
      "context_tags": [
        "evening",
        "night",
        "indoor"
      ]
    },
    {
      "id": "meditation_loving_kindness_03",
      "name": "자애 명상",
      "category": "meditation",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "편하게 앉아 눈을 감고 3번 호흡하세요. 자연스럽다면 한 손을 가슴에 얹으세요."
        },
        {
          "order": 2,
          "text": "속으로 천천히 되뇌세요. '내가 행복하기를. 건강하기를. 평안하기를.' 의미를 느끼며."
        },
        {
          "order": 3,
          "text": "아끼는 사람을 떠올려 같은 마음을 보내세요. '당신이 행복하기를. 건강하기를. 평안하기를.'"
        },
        {
          "order": 4,
          "text": "주변 사람들, 마지막엔 모든 존재로 넓혀가세요. 따뜻하고 열린 마음으로 마지막 2분을 보내세요."
        }
      ],
      "context_tags": [
        "morning",
        "indoor"
      ]
    },
    {
      "id": "meditation_mindful_walk_04",
      "name": "걷기 명상",
      "category": "meditation",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "조용한 길이나 트인 공간을 찾으세요. 잠시 멈춰 발밑의 땅을 느끼며 3번 깊게 호흡하세요."
        },
        {
          "order": 2,
          "text": "천천히 의식적으로 걷기 시작하세요. 발이 들리고 공중을 지나 내려놓이는 감각을 느끼세요."
        },
        {
          "order": 3,
          "text": "소리, 냄새, 피부에 닿는 공기로 알아차림을 넓히세요. 생각은 따라가지 말고 떠올랐다 흘려보내세요."
        },
        {
          "order": 4,
          "text": "생각이 흩어지면 발이 땅에 닿는 감각으로 부드럽게 돌아오세요. 끝까지 이어가세요."
        }
      ],
      "context_tags": [
        "morning",
        "outdoor",
        "clear"
      ]
    },
    {
      "id": "meditation_visualization_05",
      "name": "안내 심상 명상",
      "category": "meditation",
      "duration_min": 15,
      "steps": [
        {
          "order": 1,
          "text": "편하게 앉거나 누우세요. 눈을 감고 천천히 5번 깊게 호흡하며 몸을 완전히 이완하세요."
        },
        {
          "order": 2,
          "text": "평화로운 장소를 떠올리세요. 숲, 해변, 고요한 정원처럼. 색, 질감, 소리, 향까지 자세히 그리세요."
        },
        {
          "order": 3,
          "text": "그곳을 마음속으로 거닐어 보세요. 얼마나 안전하고 차분한지 느끼며 그 평온을 몸에 스미게 하세요."
        },
        {
          "order": 4,
          "text": "남은 시간은 그 공간에 머무세요. 준비되면 3번 깊게 호흡하고 천천히 방으로 돌아오세요."
        }
      ],
      "context_tags": [
        "evening",
        "indoor"
      ]
    },
    {
      "id": "meditation_gratitude_06",
      "name": "감사 돌아보기",
      "category": "meditation",
      "duration_min": 5,
      "steps": [
        {
          "order": 1,
          "text": "조용히 앉으세요. 눈을 감고 천천히 3번 호흡하며 지금 이 순간에 머무세요."
        },
        {
          "order": 2,
          "text": "오늘 진심으로 감사한 한 가지를 떠올리세요. 커피 한 잔, 다정한 말, 아침 햇살처럼 사소해도 좋아요."
        },
        {
          "order": 3,
          "text": "들이쉴 때마다 감사한 마음이 가슴에 번지게 하세요. 그 한 가지에 5번 호흡 동안 머무세요."
        },
        {
          "order": 4,
          "text": "두 가지를 더 떠올려 각각 3번 호흡하세요. 길게 감사의 숨을 내쉬며 눈을 뜨세요."
        }
      ],
      "context_tags": [
        "morning",
        "evening",
        "indoor"
      ]
    },
    {
      "id": "meditation_rain_focus_07",
      "name": "빗소리 집중 명상",
      "category": "meditation",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "빗소리가 들리는 창가에 앉으세요. 눈을 감고 그 소리가 마음을 채우게 하세요."
        },
        {
          "order": 2,
          "text": "빗소리의 리듬과 결을 느끼세요. 굵은 빗방울, 보슬비, 먼 천둥. 판단 없이 그저 들으세요."
        },
        {
          "order": 3,
          "text": "생각이 떠오르면 빗소리를 닻으로 삼으세요. 생각을 알아차릴 때마다 소리로 돌아오세요."
        },
        {
          "order": 4,
          "text": "마지막 2분은 빗소리에 맞춰 호흡하세요. 소리가 커질 때 들이쉬고 잦아들 때 내쉬세요."
        }
      ],
      "context_tags": [
        "rainy",
        "indoor"
      ]
    },
    {
      "id": "meditation_open_awareness_08",
      "name": "열린 알아차림 명상",
      "category": "meditation",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "편하게 앉으세요. 눈을 감고 3번 호흡하며 자리를 잡으세요. 몸은 고요하되 굳지 않게."
        },
        {
          "order": 2,
          "text": "한곳에 집중하지 말고 소리, 감각, 생각, 감정 모두에 알아차림을 여세요."
        },
        {
          "order": 3,
          "text": "맑은 하늘에 구름이 지나가듯 떠오르고 사라지는 경험을 관찰하세요. 당신은 구름이 아닌 하늘이에요."
        },
        {
          "order": 4,
          "text": "생각에 끌려가면 따라가지 말고 끌림 자체를 알아차리세요. 넓은 알아차림에 끝까지 머무세요."
        }
      ],
      "context_tags": [
        "afternoon",
        "indoor"
      ]
    },
    {
      "id": "meditation_wind_down_09",
      "name": "저녁 마무리 명상",
      "category": "meditation",
      "duration_min": 15,
      "steps": [
        {
          "order": 1,
          "text": "편한 자세로 눕거나 앉으세요. 가능하면 조명을 낮추고 눈을 감아 자연스럽게 호흡하세요."
        },
        {
          "order": 2,
          "text": "아침부터 지금까지 하루를 떠올려 보세요. 판단하지 말고 있었던 일을 그저 흘려보내세요."
        },
        {
          "order": 3,
          "text": "오늘 잘된 일 한 가지를 알아차리세요. 아무리 작아도 좋아요. 3번 호흡 동안 느껴보세요."
        },
        {
          "order": 4,
          "text": "내일을 위한 가벼운 마음을 정한 뒤 내려놓으세요. 마지막 5분은 천천히 호흡하며 하루를 보내주세요."
        }
      ],
      "context_tags": [
        "evening",
        "night",
        "indoor"
      ]
    },
    {
      "id": "meditation_cold_stillness_10",
      "name": "추운 날의 고요 명상",
      "category": "meditation",
      "duration_min": 10,
      "steps": [
        {
          "order": 1,
          "text": "따뜻하고 편한 자리를 찾으세요. 담요를 덮어도 좋아요. 눈을 감고 안의 온기와 밖의 한기를 느끼세요."
        },
        {
          "order": 2,
          "text": "천천히 깊게 호흡하세요. 들이쉴 때 온기가 몸에 퍼지고, 내쉴 때 긴장이 풀리는 걸 느끼세요."
        },
        {
          "order": 3,
          "text": "고요한 겨울 풍경을 떠올리세요. 조용하고 깨끗하고 차분한. 그 고요가 안에 자리 잡게 하세요."
        },
        {
          "order": 4,
          "text": "남은 시간 그 따뜻한 고요에 머무세요. 생각이 잔잔한 물 위 얼음처럼 느려지게. 서두르지 마세요."
        }
      ],
      "context_tags": [
        "cold",
        "indoor"
      ]
    },
    {
      "id": "breathing_box_4_4_01",
      "name": "박스 호흡",
      "category": "breathing",
      "duration_min": 5,
      "steps": [
        {
          "order": 1,
          "text": "바르게 앉으세요. 입으로 완전히 내쉬어 폐를 비우세요."
        },
        {
          "order": 2,
          "text": "코로 4초 들이쉬고, 4초 멈추고, 코로 4초 내쉬고, 4초 멈추세요."
        },
        {
          "order": 3,
          "text": "이것이 한 주기예요. 각 박자를 똑같이 서두르지 않고 끝까지 반복하세요."
        },
        {
          "order": 4,
          "text": "4초가 길거나 짧으면 3초나 5초로 맞추세요. 네 박자의 길이를 똑같이 하는 게 핵심이에요."
