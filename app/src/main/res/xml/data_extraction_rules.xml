<?xml version="1.0" encoding="utf-8"?>
<!--
  루밍은 온디바이스 전용·개인화 없음 정책에 따라 사용자 데이터를
  클라우드 백업 및 기기 간 전송(D2D) 대상에서 모두 제외한다.
  대상: streak_prefs / weather_prefs / slot_prefs DataStore.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore" />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
